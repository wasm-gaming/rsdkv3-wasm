{
  "name": "@wasm-gaming/engine-rsdkv3",
  "version": "0.1.3",
  "description": "RSDKv3 (Retro Software Development Kit v3) compiled to WebAssembly, with a JS SDK conforming to the wasm-gaming engine contract. Runs Sonic CD by loading Data.rsdk at runtime.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wasm-gaming/rsdkv3-wasm.git"
  },
  "bugs": {
    "url": "https://github.com/wasm-gaming/rsdkv3-wasm/issues"
  },
  "homepage": "https://github.com/wasm-gaming/rsdkv3-wasm#readme",
  "type": "module",
  "main": "./dist/rsdkv3/rsdkv3.sdk.js",
  "types": "./dist/rsdkv3/rsdkv3.sdk.d.ts",
  "exports": {
    ".": {
      "types": "./dist/rsdkv3/rsdkv3.sdk.d.ts",
      "import": "./dist/rsdkv3/rsdkv3.sdk.js"
    },
    "./options": {
      "types": "./dist/rsdkv3/rsdkv3.options.d.ts",
      "import": "./dist/rsdkv3/rsdkv3.options.js"
    },
    "./manifest": "./dist/manifest.json"
  },
  "files": [
    "dist/rsdkv3/",
    "dist/manifest.json",
    "src/rsdkv3.manifest.ts",
    "src/rsdkv3.options.ts",
    "src/rsdkv3.sdk.ts",
    "src/wasm-specs.ts",
    "README.md"
  ],
  "comment:scripts": "Build logic lives in the Makefile, not here (make build / build-sdk / build-wasm / preview).",
  "scripts": {},
  "peerDependencies": {
    "@wasm-gaming/engine-specs": "*"
  },
  "peerDependenciesMeta": {
    "@wasm-gaming/engine-specs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@wasm-gaming/engine-specs": "^0.1.0",
    "typescript": "^5.5.0"
  },
  "engineContract": "https://github.com/wasm-gaming/engine-specs",
  "license": "MIT"
}
